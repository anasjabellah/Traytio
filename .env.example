# Environment variables example for TUR SaaS platform
# Copy this file to .env (git‑ignored) and replace placeholders with real values.

# PostgreSQL connection string for Prisma
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME"

# Direct URL used by Prisma for migrations (optional but recommended)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME"
